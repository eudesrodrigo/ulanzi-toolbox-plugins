{
  "private": true,
  "type": "module",
  "workspaces": [
    "com.ulanzi.*.ulanziPlugin"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "husky": "9.1.7",
    "lint-staged": "17.0.4",
    "prettier": "^3",
    "vitest": "^3"
  }
}
