{
  "Author": "Eudes Oliveira",
  "Name": "Dev Tools",
  "Description": "Execute terminal commands with a single button press",
  "Icon": "assets/store-icon.png",
  "Version": "1.0.0",
  "Category": "Dev Tools",
  "CategoryIcon": "assets/store-icon.png",
  "CodePath": "plugin/app.js",
  "Type": "JavaScript",
  "UUID": "com.ulanzi.ulanzistudio.toolbox",
  "Actions": [
    {
      "Name": "Run Command",
      "Icon": "plugin/icons/run-command/idle.png",
      "PropertyInspectorPath": "property-inspector/run-command/inspector.html",
      "States": [{ "Name": "Idle", "Image": "plugin/icons/run-command/idle.png" }],
      "Tooltip": "Execute a terminal command",
      "UUID": "com.ulanzi.ulanzistudio.toolbox.runcommand",
      "SupportedInMultiActions": true,
      "DisableAutomaticStates": true,
      "Controllers": ["Keypad"]
    },
    {
      "Name": "Run Script",
      "Icon": "plugin/icons/run-script/idle.png",
      "PropertyInspectorPath": "property-inspector/run-script/inspector.html",
      "States": [{ "Name": "Idle", "Image": "plugin/icons/run-script/idle.png" }],
      "Tooltip": "Execute a script file",
      "UUID": "com.ulanzi.ulanzistudio.toolbox.runscript",
      "SupportedInMultiActions": true,
      "DisableAutomaticStates": true,
      "Controllers": ["Keypad"]
    },
    {
      "Name": "SSH Command",
      "Icon": "plugin/icons/ssh-command/idle.png",
      "PropertyInspectorPath": "property-inspector/ssh-command/inspector.html",
      "States": [{ "Name": "Idle", "Image": "plugin/icons/ssh-command/idle.png" }],
      "Tooltip": "Execute a command on a remote host via SSH",
      "UUID": "com.ulanzi.ulanzistudio.toolbox.sshcommand",
      "SupportedInMultiActions": true,
      "DisableAutomaticStates": true,
      "Controllers": ["Keypad"]
    },
    {
      "Name": "Deep Clean",
      "Icon": "plugin/icons/deep-clean/idle.png",
      "PropertyInspectorPath": "property-inspector/deep-clean/inspector.html",
      "States": [
        { "Name": "Idle", "Image": "plugin/icons/deep-clean/idle.png" },
        { "Name": "Running", "Image": "plugin/icons/deep-clean/running.png" }
      ],
      "Tooltip": "Show disk usage and run cleanup",
      "UUID": "com.ulanzi.ulanzistudio.toolbox.deepclean",
      "SupportedInMultiActions": false,
      "DisableAutomaticStates": true,
      "Controllers": ["Keypad"]
    },
    {
      "Name": "AI Clean",
      "Icon": "plugin/icons/deep-clean/idle.png",
      "PropertyInspectorPath": "property-inspector/ai-clean/inspector.html",
      "States": [
        { "Name": "Idle", "Image": "plugin/icons/deep-clean/idle.png" },
        { "Name": "Running", "Image": "plugin/icons/deep-clean/running.png" }
      ],
      "Tooltip": "AI-powered disk cleanup via Claude Code",
      "UUID": "com.ulanzi.ulanzistudio.toolbox.aiclean",
      "SupportedInMultiActions": false,
      "DisableAutomaticStates": true,
      "Controllers": ["Keypad"]
    }
  ],
  "OS": [{ "Platform": "mac", "MinimumVersion": "12.0" }],
  "Software": { "MinVersion": "3.0.0" }
}
